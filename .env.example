# Database
DATABASE_URL="file:./packages/db/prisma/dev.db"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# AI APIs
GEMINI_API_KEY="your-gemini-api-key"
